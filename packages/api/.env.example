# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Supabase, Railway Postgres, etc.)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Use a long random string in production, e.g.: openssl rand -hex 64
JWT_SECRET="change-me-use-a-long-random-string"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your Vercel deployment URLs)
WEB_URL="https://coolcliq.vercel.app"
ADMIN_URL="https://coolcliq-admin.vercel.app"

# ─── GPS Validation ───────────────────────────────────────────────────────────
# Set to true only in development to bypass GPS check-in validation
SKIP_GPS_VALIDATION=false

# ─── OTP / Twilio (optional) ──────────────────────────────────────────────────
# Leave empty to use the mock OTP bypass (code: 000000) — dev only
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
