# CoolCliq Environment Configuration
# Copy this file to .env and fill in your values

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/coolcliq_dev"

# Auth
JWT_SECRET="coolcliq-dev-secret-change-in-production-use-long-random-string"

# API Server
PORT=4000
NODE_ENV=development

# CORS origins
WEB_URL="http://localhost:3000"
ADMIN_URL="http://localhost:3001"

# GPS Validation (set to true to bypass GPS check in development)
SKIP_GPS_VALIDATION=true

# OTP (leave empty to use mock 000000 bypass)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Google Maps (required for map view)
# NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Frontend API URLs
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
NEXT_PUBLIC_WS_URL="http://localhost:4000"
